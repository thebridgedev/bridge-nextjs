# =============================================================================
# bridge-nextjs Demo Runtime Configuration (developer mode)
# =============================================================================
# Copy this file to `config/.env.local` and fill in the values.
# `config/.env.local` is gitignored and must NOT be committed.
#
# Loaded by the demo's `npm run dev` script (port 3000). For TEST runs, see
# `config/.env.demo.test.local` (auto-written by `e2e/playwright/pre-setup.ts`).
# =============================================================================

# [REQUIRED] Your Bridge app ID — get one from the Bridge admin UI for your
# tenant. The demo's `npm run dev` will fail to authenticate without this.
NEXT_PUBLIC_BRIDGE_APP_ID=

# [HAS DEFAULT: https://api.thebridge.dev] auth-core's root URL. Set to your
# local bridge-api (e.g. http://localhost:3200) when developing against a
# local backend. auth-core appends `/auth`, `/cloud-views`, etc. internally.
# NEXT_PUBLIC_BRIDGE_API_BASE_URL=https://api.thebridge.dev

# [HAS DEFAULT: false] Verbose `logger.debug` output. Set to `true` while
# debugging integration issues.
# NEXT_PUBLIC_BRIDGE_DEBUG=true
