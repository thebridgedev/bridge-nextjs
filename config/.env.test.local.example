# =============================================================================
# bridge-nextjs Playwright E2E Test Configuration
# =============================================================================
# Copy this file to config/.env.test.local and fill in the values.
# The .env.test.local file is gitignored and should NOT be committed.
#
# Legend:
#   [REQUIRED]       — must be set
#   [HAS DEFAULT]    — optional, default value shown in comment
# =============================================================================

# [REQUIRED] API key for bridge-api test data endpoints (same key as in bridge-api config)
PLAYWRIGHT_TEST_API_KEY=

# [HAS DEFAULT: BRIDGE_NEXTJS_TEST_DASHBOARD] App domain for test app
# APP_DOMAIN=BRIDGE_NEXTJS_TEST_DASHBOARD

# [HAS DEFAULT: http://localhost:3001] Demo app URL (must match webServer in playwright.config)
# LOCAL_BASE_URL=http://localhost:3001

# [HAS DEFAULT: http://localhost:3200] Local bridge-api / test data API
# LOCAL_TEST_DATA_API_URL=http://localhost:3200

# Stage/Prod — required when running --project=stage or --project=prod
# STAGE_AUTH_BASE_URL=...
# STAGE_CLOUD_VIEWS_URL=...
# STAGE_TEST_DATA_API_URL=...
# PROD_TEST_DATA_API_URL=...
