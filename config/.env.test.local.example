# =============================================================================
# bridge-nextjs Playwright E2E Test Configuration
# =============================================================================
# Copy this file to `config/.env.test.local` and fill in the values.
# `config/.env.test.local` is gitignored and must NOT be committed.
#
# Legend:
#   [REQUIRED]    — must be set
#   [HAS DEFAULT] — optional, default value shown in comment
# =============================================================================

# [REQUIRED] API key for bridge-api's playwright test endpoints
# (same key as in your bridge-api `.env` under PLAYWRIGHT_TEST_API_KEY).
PLAYWRIGHT_TEST_API_KEY=

# [HAS DEFAULT: BRIDGE_NEXTJS_TEST_DASHBOARD] App domain for the test app
# APP_DOMAIN=BRIDGE_NEXTJS_TEST_DASHBOARD

# [HAS DEFAULT: http://localhost:3010] Demo app URL — must match webServer in
# playwright.config.ts. :3010 is bridge-nextjs's test harness (distinct from
# :3000 dev port and :3001 bridge-svelte test harness).
# LOCAL_BASE_URL=http://localhost:3010

# [HAS DEFAULT: http://localhost:3200] Local bridge-api (slot 0). Used for
# test-data setup AND as `apiBaseUrl` for auth-core. Override per worktree
# slot (slot 1 = :3300, slot 2 = :3400, etc).
# LOCAL_TEST_DATA_API_URL=http://localhost:3200
# LOCAL_API_BASE_URL=http://localhost:3200    # Defaults to LOCAL_TEST_DATA_API_URL

# [HAS DEFAULT: playwright-e2e@example.com / helloworld] Test owner credentials
# TEST_OWNER_EMAIL=playwright-e2e@example.com
# TEST_OWNER_PASSWORD=helloworld

# ─────────────────────────────────────────────────────────────────────────────
# Stage / Prod — required when running --project=stage or --project=prod.
# Leave commented unless you actually need to run against those environments.
# `*_API_BASE_URL` is the auth-core root (no /auth or /cloud-views suffix).
# ─────────────────────────────────────────────────────────────────────────────
# STAGE_API_BASE_URL=
# STAGE_TEST_DATA_API_URL=
# PROD_API_BASE_URL=
# PROD_TEST_DATA_API_URL=
